{
  "entities": {
    "Installer": {
      "title": "Installer",
      "type": "object",
      "description": "Represents an individual installer.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a single work order.",
      "properties": {
        "id": { "type": "string" },
        "objectName": { "type": "string" },
        "workDescription": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string" },
        "installerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "objectName", "workDescription", "dueDate", "status", "installerId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/installers/{id}": { "schema": "Installer", "description": "Installer profiles" },
    "/orders/{id}": { "schema": "Order", "description": "Work orders" },
    "/notifications/{id}": { "schema": "Notification", "description": "User notifications" }
  }
}