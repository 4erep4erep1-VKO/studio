{
  "entities": {
    "Profile": {
      "title": "Profile",
      "type": "object",
      "description": "User profile with role information",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "installer"] },
        "pin": { "type": "string" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents a single work order.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image_urls": { "type": "array", "items": { "type": "string" } },
        "due_date": { "type": "string", "format": "date", "nullable": true },
        "status": { "type": "string" },
        "assigned_to": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "status", "assigned_to", "created_at"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "description": "Comment on a work order",
      "properties": {
        "id": { "type": "string" },
        "order_id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "order_id", "user_id", "user_name", "message", "created_at"]
    }
  },
  "database": "Supabase (PostgreSQL)",
  "auth": {
    "provider": "Supabase Auth",
    "methods": ["email/password", "roles from profiles table"]
  },
  "storage": {
    "order_photos": "Supabase Storage bucket for order images",
    "public_url_pattern": "https://yourproject.supabase.co/storage/v1/object/public/order-photos/{filename}"
  }
}