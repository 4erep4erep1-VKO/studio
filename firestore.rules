
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK ORDER MANAGEMENT SYSTEM - SECURITY ARCHITECTURE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /** Настройки приложения доступны для чтения всем (проверка PIN), запись только админу */
    match /settings/app {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/roles_admin/any_admin);
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /roles_installer/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Разрешаем чтение всем авторизованным. 
      // Firestore сам ограничит выдачу документов согласно фильтрам (installerId) в запросе.
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }

    match /accessLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /notifications/{notificationId} {
      // Каждый видит только свои уведомления
      allow read, update, delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }
  }
}
