rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Настройки приложения: открыты для чтения (для проверки PIN)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Роли пользователей
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn();
    }

    match /roles_installer/{userId} {
      allow read, write: if isSignedIn();
    }

    // Профили монтажников
    match /installers/{installerId} {
      allow read, write: if isSignedIn();
    }

    // Заказы: разрешаем доступ всем авторизованным. 
    // Фильтрация данных происходит в коде через .where()
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // Уведомления: разрешаем доступ всем авторизованным.
    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    // Логи доступа
    match /accessLogs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}