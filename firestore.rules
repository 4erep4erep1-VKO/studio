
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK ORDER MANAGEMENT SYSTEM - SECURITY ARCHITECTURE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isInstaller() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_installer/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /** Настройки приложения доступны всем для проверки PIN-кода */
    match /settings/app {
      allow get: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/roles_admin/any_admin);
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /roles_installer/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /installers/{installerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Администратор видит всё. Монтажник видит только свои, если запрос содержит фильтр.
      // Важно: для 'list' Firestore проверяет, что правило ИСТИННО для всех возможных результатов.
      allow get: if isAdmin() || (isSignedIn() && resource.data.installerId != null);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); 
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.installerId != null);
    }

    match /accessLogs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId != null;
      allow create: if isSignedIn();
    }
  }
}
