
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK ORDER MANAGEMENT SYSTEM - SECURITY ARCHITECTURE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Получаем ID монтажника, привязанный к текущей сессии пользователя
    function getInstallerId() {
      return get(/databases/$(database)/documents/roles_installer/$(request.auth.uid)).data.installerId;
    }

    function isInstaller() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_installer/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /** Настройки приложения доступны для чтения всем (проверка PIN), запись только админу */
    match /settings/app {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/roles_admin/any_admin);
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /roles_installer/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Администратор видит всё, монтажник — только свои заказы
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isInstaller() && resource.data.installerId == getInstallerId()) ||
        (resource == null) // Для первоначального листинга с фильтрами
      );
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }

    match /accessLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /notifications/{notificationId} {
      // Каждый видит только свои уведомления (по прямому UID или по привязке к монтажнику)
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        (isInstaller() && resource.data.userId == getInstallerId())
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        (isInstaller() && resource.data.userId == getInstallerId())
      );
    }
  }
}
