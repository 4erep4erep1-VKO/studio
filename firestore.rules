
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK ORDER MANAGEMENT SYSTEM - SECURITY ARCHITECTURE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /** Настройки приложения доступны всем для проверки при входе */
    match /settings/app {
      allow get: if true;
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/roles_admin/any_admin));
    }

    match /roles_admin/{userId} {
      allow get: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /installers/{installerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }

    match /accessLogs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }
  }
}
