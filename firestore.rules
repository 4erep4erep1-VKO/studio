
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательная функция для проверки авторизации
    function isSignedIn() {
      return request.auth != null;
    }

    // Правила для настроек: чтение разрешено всем для проверки PIN
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Роли: запись только самому себе
    match /roles_admin/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /roles_installer/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Профили монтажников
    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Заказы: разрешаем list всем вошедшим (фильтрация в коде), 
    // но ограничиваем запись и получение конкретного документа
    match /orders/{orderId} {
      allow list: if isSignedIn();
      allow get, update: if isSignedIn();
      allow create, delete: if isSignedIn();
    }

    // Логи доступа: только для админа (в MVP разрешаем запись всем для логов)
    match /accessLogs/{logId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Уведомления: разрешаем list всем вошедшим
    match /notifications/{notificationId} {
      allow list: if isSignedIn();
      allow get, update, delete, create: if isSignedIn();
    }
  }
}
