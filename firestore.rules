rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Правила для ролей администраторов
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Только через консоль или системно
    }

    // Правила для ролей пользователей/монтажников
    match /roles_installer/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Профили монтажников
    match /installers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Настройки приложения (включая PIN)
    match /settings/app {
      allow read: if true; // Разрешаем чтение всем для проверки PIN на входе
      allow write: if isAdmin();
    }

    // Заказы
    match /orders/{id} {
      // Разрешаем list всем вошедшим. Код должен использовать .where('installerId', '==', ...) для фильтрации.
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Уведомления
    match /notifications/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Логи доступа
    match /accessLogs/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}