rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Настройки: чтение разрешено всем для проверки PIN
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Роли: чтение разрешено всем вошедшим
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /roles_installer/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Профили монтажников
    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Заказы: разрешаем list всем вошедшим. Безопасность данных обеспечивается фильтром в коде.
    // get/update доступны только если пользователь авторизован.
    match /orders/{orderId} {
      allow list: if isSignedIn();
      allow get, update, create, delete: if isSignedIn();
    }

    // Логи доступа: разрешаем запись всем вошедшим для аудита.
    match /accessLogs/{logId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Уведомления: разрешаем list всем вошедшим.
    match /notifications/{notificationId} {
      allow list: if isSignedIn();
      allow get, update, delete, create: if isSignedIn();
    }
  }
}