
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Вспомогательные функции ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isInstaller() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_installer/$(request.auth.uid));
    }

    function getInstallerId() {
      return get(/databases/$(database)/documents/roles_installer/$(request.auth.uid)).data.installerId;
    }

    // --- Правила коллекций ---

    /** Настройки приложения: чтение для всех авторизованных (для проверки PIN), запись только админу */
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Роли администраторов */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    /** Связка UID пользователя и ID монтажника */
    match /roles_installer/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    /** Профили монтажников */
    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Заказы */
    match /orders/{orderId} {
      // Разрешаем list, если пользователь вошел. Фильтрация идет в коде.
      allow list: if isSignedIn();
      allow get, update: if isSignedIn() && (
        isAdmin() || 
        (isInstaller() && resource.data.installerId == getInstallerId())
      );
      allow create, delete: if isAdmin();
    }

    /** Логи доступа */
    match /accessLogs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    /** Уведомления */
    match /notifications/{notificationId} {
      // Разрешаем list всем вошедшим. Безопасность обеспечивается фильтром в запросе.
      allow list: if isSignedIn();
      allow get, update, delete: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        (isInstaller() && resource.data.userId == getInstallerId())
      );
      allow create: if isSignedIn();
    }
  }
}
