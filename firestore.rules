rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK ORDER MANAGEMENT SYSTEM - SECURITY ARCHITECTURE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAssignedToOrder(resourceData) {
      // В данной версии приложения мы доверяем анонимной сессии и фильтруем по installerId на клиенте
      return isSignedIn();
    }

    // --- Collection Rules ---

    /** Настройки приложения (PIN-код) доступны для чтения всем для проверки при входе */
    match /settings/app {
      allow get: if true;
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/roles_admin/any));
    }

    match /roles_admin/{userId} {
      allow get: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();
      // Позволяем пользователю зарегистрировать себя как админа (предполагается проверка PIN в UI)
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /installers/{installerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isAssignedToOrder(resource.data);
    }

    match /accessLogs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }
  }
}