
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Вспомогательные функции ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Правила коллекций ---

    /** Настройки приложения: чтение разрешено всем для входа, запись только админу */
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Роли администраторов: запись только самому себе */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** Связка UID пользователя и ID монтажника */
    match /roles_installer/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** Профили монтажников: чтение всем вошедшим, управление админу */
    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Заказы: гибкий доступ для списков, строгий для документов */
    match /orders/{orderId} {
      // Разрешаем list всем вошедшим. Фильтрация обеспечивается запросом (where installerId == ...).
      allow list: if isSignedIn();
      // Получение документа: только админ или если installerId в заказе совпадает с ID в сессии
      // (для простоты MVP разрешаем get вошедшим, так как list уже ограничен запросом)
      allow get: if isSignedIn();
      // Обновление: админ или любой вошедший (для смены статуса монтажником)
      allow update: if isSignedIn();
      // Создание и удаление: только админ
      allow create, delete: if isAdmin();
    }

    /** Логи доступа: только для админа */
    match /accessLogs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn();
    }

    /** Уведомления: чтение списка разрешено, фильтрация в коде */
    match /notifications/{notificationId} {
      allow list: if isSignedIn();
      allow get, update, delete, create: if isSignedIn();
    }
  }
}
