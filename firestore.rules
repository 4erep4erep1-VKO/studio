
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WORK ORDER MANAGEMENT SYSTEM - SECURITY ARCHITECTURE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Проверка роли администратора через коллекцию roles_admin
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Получаем ID монтажника из документа роли пользователя
    function getInstallerId() {
      return get(/databases/$(database)/documents/roles_installer/$(request.auth.uid)).data.installerId;
    }

    // Проверка наличия роли монтажника
    function isInstaller() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_installer/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /** Настройки приложения: чтение доступно всем для проверки PIN, запись только админу */
    match /settings/app {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/roles_admin/any_admin);
    }

    /** Роли администраторов */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    /** Связка UID пользователя и ID монтажника */
    match /roles_installer/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    /** Профили монтажников */
    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /** Заказы */
    match /orders/{orderId} {
      // Администратор видит всё. Монтажник может запрашивать (list) заказы, 
      // но доступ к данным (get) ограничен только его ID.
      allow list: if isSignedIn();
      allow get, update: if isSignedIn() && (
        isAdmin() || 
        (isInstaller() && resource.data.installerId == getInstallerId())
      );
      allow create, delete: if isAdmin();
    }

    /** Логи доступа */
    match /accessLogs/{logId} {
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    /** Уведомления */
    match /notifications/{notificationId} {
      // Разделяем list и get для обхода ограничений на использование get() в запросах
      allow list: if isSignedIn();
      allow get, update, delete: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid || 
        (isInstaller() && resource.data.userId == getInstallerId())
      );
      allow create: if isSignedIn();
    }
  }
}
