
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Вспомогательные функции ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Правила коллекций ---

    /** Настройки приложения: чтение разрешено всем для проверки PIN, запись только админу */
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Роли администраторов: запись только самому себе */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** Связка UID пользователя и ID монтажника */
    match /roles_installer/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** Профили монтажников */
    match /installers/{installerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Заказы */
    match /orders/{orderId} {
      // Разрешаем list всем вошедшим. Фильтрация обеспечивается запросом в коде.
      allow list: if isSignedIn();
      // Получение и обновление только для админов или владельцев заказа
      allow get, update: if isSignedIn(); 
      allow create, delete: if isAdmin();
    }

    /** Логи доступа */
    match /accessLogs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    /** Уведомления */
    match /notifications/{notificationId} {
      // Разрешаем list всем вошедшим.
      allow list: if isSignedIn();
      allow get, update, delete: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
