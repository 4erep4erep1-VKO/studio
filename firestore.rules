rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Вспомогательные функции
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Настройки приложения (включая PIN)
    match /settings/app {
      allow read: if true; // Разрешаем чтение всем для проверки PIN на входе
      allow write: if isSignedIn();
    }

    // Роли пользователей
    match /roles_admin/{uid} {
      allow read, write: if isSignedIn();
    }

    match /roles_installer/{uid} {
      allow read, write: if isSignedIn();
    }

    // Профили монтажников
    match /installers/{id} {
      allow read, write: if isSignedIn();
    }

    // Заказы
    match /orders/{id} {
      allow read, write: if isSignedIn();
    }

    // Уведомления
    match /notifications/{id} {
      allow read, write: if isSignedIn();
    }

    // Логи доступа
    match /accessLogs/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
    }
  }
}